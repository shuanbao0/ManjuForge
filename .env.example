# 阿里云 DashScope API Key (用于通义千问等模型)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 阿里云 Access Key (用于 OSS、视频超分等服务)
ALIBABA_CLOUD_ACCESS_KEY_ID=your_aliyun_access_key_id_here
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_aliyun_access_key_secret_here

# OSS 配置 (可选，用于图片/视频存储)
OSS_BUCKET_NAME=your_bucket_name
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BASE_PATH=comic_gen/

# Kling AI 配置 (可选，用于 Kling 视频生成)
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here

# Vidu AI 配置 (可选，用于 Vidu 视频生成)
VIDU_API_KEY=your_vidu_api_key_here

# LLM 多模型适配 (可选)
# 默认使用 DashScope (通过 OpenAI 兼容接口调用，只需上方 DASHSCOPE_API_KEY 即可)
# LLM_PROVIDER=dashscope
#
# 如需切换到第三方 OpenAI 兼容 API (OpenAI/DeepSeek/Ollama 等):
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
#
# DeepSeek 示例:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_deepseek_api_key
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
#
# 本地 Ollama 示例:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=qwen2.5:72b

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000

# ===============================
# API 端点配置 (可选，海外部署时切换到国际端点)
# 命名约定: {PROVIDER}_BASE_URL
# ===============================
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com
# KLING_BASE_URL=https://api.klingai.com/v1
# VIDU_BASE_URL=https://api.vidu.cn/ent/v2

# ===============================
# Docker 部署 (docker-compose.deploy.yml) - 中间件配置
# 整份 .env **完全可选**：所有 provider key（DashScope / Kling / Vidu / OSS）
# 都可以登录后在「设置」页面配置，加密存到 auth 数据库里。
# 这一段只在你想覆盖 compose 默认值（比如改 Postgres 密码、镜像 tag）时才需要。
# 默认不带反向代理：前端 3000、后端 17177 直接对外，TLS 由部署方在外层自行处理。
# ===============================

# Postgres (替换内置 SQLite)
# 容器内默认 DATABASE_URL 已指向 compose 中的 postgres 服务，无需手动设置。
# 自托管 Postgres 时取消注释并改成实际连接串：
# DATABASE_URL=postgresql+psycopg2://USER:PASS@HOST:5432/DB
POSTGRES_USER=manjuforge
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=manjuforge

# Redis (供未来 Celery / 限流使用，当前仅占位)
# REDIS_URL=redis://redis:6379/0

# MinIO (S3 兼容对象存储)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-please
MINIO_BUCKET=manju-forge
# STORAGE_REGION=us-east-1

# 应用数据目录 (容器内挂卷路径；本地运行不要设置)
# MANJU_FORGE_DATA_DIR=/app/data

# 实例密钥 (留空则首次启动自动生成并写入数据卷的 instance.json)
# MANJU_FORGE_JWT_SECRET=
# MANJU_FORGE_MASTER_KEY=
